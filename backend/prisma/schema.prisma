
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// Tabela de usuários
model Usuario {
  id        Int      @id @default(autoincrement()) 
  nome      String
  email     String   @unique 
  senha     String           // aqui ficará o hash da senha, nunca a senha pura
  criadoEm DateTime @default(now())

  // Relações: um usuário pode ter vários itens na lista de desejos e várias avaliações
  listaDesejos  Wishlist[]
  avaliacoes    Review[]
}

model Wishlist {
  id        Int      @id @default(autoincrement())
  usuarioId Int      
  jogoId    Int      
  jogoNome  String
  jogoImagem String

  criadoEm DateTime @default(now())

 
  usuario   Usuario  @relation(fields: [usuarioId], references: [id])
  @@unique([usuarioId, jogoId])
}

model Review {
  id        Int      @id @default(autoincrement())
  usuarioId Int
  jogoId    Int
  jogoNome  String
  nota      Float    // nota de 0 a 10
  comentario String?

  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt // atualiza automaticamente quando o registro muda

  usuario  Usuario  @relation(fields: [usuarioId], references: [id])
  @@unique([usuarioId, jogoId]) //comentario unico 
}
